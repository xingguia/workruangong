<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="设置计划"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="选择当天的计划类型"
        android:textColor="#666666"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/statusRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radioRest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="休息日"
            android:textColor="#000000"
            android:textSize="16sp"
            android:padding="12dp"
            android:buttonTint="#FF6B35" />

        <RadioButton
            android:id="@+id/radioWorkout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="锻炼日"
            android:textColor="#000000"
            android:textSize="16sp"
            android:padding="12dp"
            android:buttonTint="#FF6B35" />
    </RadioGroup>

    <!-- Completion status (only visible when workout is selected) -->
    <LinearLayout
        android:id="@+id/completionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="完成状态"
            android:textColor="#666666"
            android:textSize="14sp" />

        <RadioGroup
            android:id="@+id/completionRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioPending"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="未完成"
                android:textColor="#000000"
                android:textSize="14sp"
                android:padding="8dp"
                android:buttonTint="#FFA502" />

            <RadioButton
                android:id="@+id/radioCompleted"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="已完成"
                android:textColor="#000000"
                android:textSize="14sp"
                android:padding="8dp"
                android:buttonTint="#2ED573" />
        </RadioGroup>
    </LinearLayout>

</LinearLayout>
