<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_card">

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="设置展示徽章"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="点击空白位置选择要展示的徽章"
        android:textColor="@color/text_muted"
        android:textSize="12sp" />

    <!-- 3个展示位置预览 -->
    <LinearLayout
        android:id="@+id/slotsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- 位置1 -->
        <LinearLayout
            android:id="@+id/slot1Container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="左"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <FrameLayout
                android:id="@+id/slot1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_badge_slot_empty"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/slot1Icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"
                    android:src="@drawable/ic_star"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/slot1Label"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/text_muted"
                    android:textSize="24sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/slot1BadgeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:maxWidth="70dp"
                android:text=""
                android:textColor="@color/vip_gold"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 位置2 -->
        <LinearLayout
            android:id="@+id/slot2Container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="中"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <FrameLayout
                android:id="@+id/slot2"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_badge_slot_empty"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/slot2Icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"
                    android:src="@drawable/ic_star"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/slot2Label"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/text_muted"
                    android:textSize="24sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/slot2BadgeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:maxWidth="70dp"
                android:text=""
                android:textColor="@color/vip_gold"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 位置3 -->
        <LinearLayout
            android:id="@+id/slot3Container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="右"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <FrameLayout
                android:id="@+id/slot3"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_badge_slot_empty"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/slot3Icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"
                    android:src="@drawable/ic_star"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/slot3Label"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/text_muted"
                    android:textSize="24sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/slot3BadgeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:maxWidth="70dp"
                android:text=""
                android:textColor="@color/vip_gold"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- 可选择的徽章列表 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="点击选择展示的徽章"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:maxHeight="200dp">

        <LinearLayout
            android:id="@+id/badgeListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </androidx.core.widget.NestedScrollView>

    <!-- 按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelBtn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="取消"
            android:textColor="@color/text_secondary"
            app:backgroundTint="@color/white_5"
            app:strokeColor="@color/border_color"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirmBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="确定"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>
